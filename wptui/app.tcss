/* wp-tui styles */

.error {
    color: $error;
}

/* Connect screen */
#connect-box {
    width: 60;
    max-width: 90%;
    height: auto;
    margin: 2 4;
    padding: 1 2;
    border: round $primary;
}

#connect-title {
    text-style: bold;
    margin-bottom: 1;
}

#connect-box Input,
#connect-box Select {
    margin-bottom: 1;
}

#connect-buttons {
    height: auto;
    align-horizontal: right;
}

#connect-status {
    margin-top: 1;
    height: auto;
}

/* Post list screen */
#post-search {
    dock: top;
}

#post-table {
    height: 1fr;
}

#post-status {
    dock: bottom;
    height: auto;
    padding: 0 1;
    color: $text-muted;
}

/* Editor screen */
#editor-title {
    dock: top;
    text-style: bold;
}

#editor-status {
    dock: bottom;
    height: auto;
    padding: 0 1;
    color: $text-muted;
}

BlockCanvas {
    height: 1fr;
    padding: 0 1;
}

TextBlockEditor {
    height: auto;
    margin-bottom: 1;
    border-left: wide $primary 30%;
    padding-left: 1;
}

.block-label {
    color: $text-muted;
    text-style: italic;
}

.container-label {
    color: $accent;
    text-style: bold;
    margin-bottom: 1;
}

.separator-rule {
    color: $text-muted;
    margin-bottom: 1;
}

SeparatorCard {
    height: auto;
    border-left: wide $secondary 40%;
    padding-left: 1;
}

SeparatorCard:focus-within, OpaqueCard:focus, SeparatorCard:focus {
    border-left: wide $accent;
}

.nested {
    margin-left: 2;
}

ImageCard {
    height: auto;
    margin-bottom: 1;
    border-left: wide $success 40%;
    padding-left: 1;
}

ImageCard:focus-within {
    border-left: wide $success;
}

.image-label {
    color: $success;
    text-style: bold;
}

.image-field {
    margin-bottom: 1;
}

.block-body {
    height: auto;
    max-height: 20;
}

InlineMarkdownArea.vim {
    border: round $accent;
}

OpaqueCard {
    height: auto;
    margin-bottom: 1;
    padding: 0 1;
    border-left: wide $warning 40%;
    background: $panel;
}

.opaque-label {
    color: $warning;
    text-style: bold;
}

.opaque-preview {
    color: $text-muted;
}

/* Post settings screen */
#settings-form {
    height: 1fr;
    padding: 1 2;
}

.settings-title {
    text-style: bold;
    color: $accent;
    margin-bottom: 1;
}

.settings-label {
    color: $text-muted;
    margin-top: 1;
}

#settings-form Input, #settings-form Select, #settings-form Button {
    margin-bottom: 1;
}

/* Image upload modal */
ImageUploadModal {
    align: center middle;
}

#upload-modal {
    width: 64;
    max-width: 90%;
    height: auto;
    padding: 1 2;
    border: round $success;
    background: $surface;
}

.upload-title {
    text-style: bold;
    color: $success;
    margin-bottom: 1;
}

#upload-modal Input, #upload-modal Button {
    margin-bottom: 1;
}

/* Media picker modal */
MediaPickerModal {
    align: center middle;
}

#media-picker {
    width: 70;
    max-width: 90%;
    height: auto;
    max-height: 80%;
    padding: 1 2;
    border: round $success;
    background: $surface;
}

.media-title {
    text-style: bold;
    color: $success;
    margin-bottom: 1;
}

#media-list {
    height: auto;
    max-height: 15;
    margin-bottom: 1;
}

#media-picker Input, #media-picker Button {
    margin-bottom: 1;
}

/* Term picker modal */
TermPicker {
    align: center middle;
}

#term-picker {
    width: 60;
    max-width: 90%;
    height: auto;
    max-height: 80%;
    padding: 1 2;
    border: round $primary;
    background: $surface;
}

.term-title {
    text-style: bold;
    margin-bottom: 1;
}

#term-list {
    height: auto;
    max-height: 15;
    margin-bottom: 1;
}

#term-add-row {
    height: auto;
}

/* View post screen */
#view-title {
    dock: top;
    text-style: bold;
    padding: 0 1;
}

#view-content {
    height: 1fr;
}

#view-status {
    dock: bottom;
    height: auto;
    padding: 0 1;
    color: $text-muted;
}
